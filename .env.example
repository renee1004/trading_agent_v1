# ===========================================
# AI Trading Agent - 환경변수 설정
# ===========================================
# 이 파일을 복사해서 .env 로 만들어 사용하세요.
# Railway에서는 Variables 탭에서 직접 입력합니다.
# ===========================================

# 데이터베이스 (Railway PostgreSQL 자동 생성)
# Railway에서 PostgreSQL 서비스 추가 시 자동으로 설정됨
DATABASE_URL=postgresql://user:password@host:5432/dbname

# KIS API 설정 (대시보드에서 입력하거나 환경변수로 설정)
# 모의투자: https://koreainvestment.com 폼로그인 > API 신청
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_DEMO=true

# NextAuth (선택사항)
NEXTAUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# 서버 설정
PORT=3000
NODE_ENV=production
